{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "eval-result.schema.json",
  "title": "Skill Eval Result",
  "description": "Result output from a skill evaluation run",
  "type": "object",
  "required": ["skill", "suite_version", "status", "cases", "summary", "timestamp"],
  "properties": {
    "skill": {
      "type": "string",
      "description": "Name of the skill that was evaluated"
    },
    "suite_version": {
      "type": "string",
      "description": "Version of the eval suite used"
    },
    "skill_type": {
      "type": "string",
      "enum": ["capability-uplift", "encoded-preference", "unknown"],
      "description": "Classification of the skill being evaluated",
      "default": "unknown"
    },
    "mode": {
      "type": "string",
      "enum": ["eval", "benchmark", "compare", "obsolescence"],
      "description": "Evaluation mode used"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "partial", "error"],
      "description": "Overall evaluation result"
    },
    "pass_rate": {
      "type": "number",
      "description": "Fraction of cases that passed (0.0-1.0)",
      "minimum": 0,
      "maximum": 1
    },
    "mean_score": {
      "type": "number",
      "description": "Mean score across all cases (0.0-1.0)",
      "minimum": 0,
      "maximum": 1
    },
    "cases": {
      "type": "array",
      "description": "Per-case evaluation results",
      "items": {
        "type": "object",
        "required": ["case_id", "status", "scoring_method", "score"],
        "properties": {
          "case_id": {
            "type": "string",
            "description": "ID of the eval case"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "error", "timeout", "skipped"],
            "description": "Result for this case"
          },
          "scoring_method": {
            "type": "string",
            "enum": ["binary", "rubric", "llm-judge"],
            "description": "Scoring method used"
          },
          "score": {
            "type": "number",
            "description": "Normalized score (0.0-1.0)",
            "minimum": 0,
            "maximum": 1
          },
          "dimensions": {
            "type": "array",
            "description": "Per-dimension scores (rubric method only)",
            "items": {
              "type": "object",
              "required": ["name", "score", "weight"],
              "properties": {
                "name": { "type": "string" },
                "score": { "type": "number", "minimum": 0, "maximum": 1 },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 },
                "rationale": { "type": "string" }
              }
            }
          },
          "assertions": {
            "type": "array",
            "description": "Results of mechanical assertions",
            "items": {
              "type": "object",
              "required": ["type", "value", "passed"],
              "properties": {
                "type": { "type": "string" },
                "value": { "type": "string" },
                "passed": { "type": "boolean" },
                "actual": { "type": "string" }
              }
            }
          },
          "tokens_used": {
            "type": "integer",
            "description": "Tokens consumed for this case",
            "minimum": 0
          },
          "duration_seconds": {
            "type": "number",
            "description": "Time taken to evaluate this case",
            "minimum": 0
          },
          "error": {
            "type": ["object", "null"],
            "description": "Error details if the case failed to execute",
            "properties": {
              "phase": {
                "type": "string",
                "enum": ["setup", "execution", "scoring", "assertion"],
                "description": "Which phase failed"
              },
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "details": {
                "type": "string",
                "description": "Detailed error output"
              }
            },
            "required": ["phase", "message"]
          }
        }
      }
    },
    "comparison": {
      "type": ["object", "null"],
      "description": "A/B comparison results (compare mode only)",
      "properties": {
        "skill_loaded": {
          "type": "object",
          "description": "Metrics with skill loaded (arm A)",
          "properties": {
            "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "mean_score": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "baseline": {
          "type": "object",
          "description": "Metrics without skill (arm B)",
          "properties": {
            "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "mean_score": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "uplift": {
          "type": "object",
          "properties": {
            "pass_rate_delta": { "type": "number" },
            "mean_score_delta": { "type": "number" },
            "verdict": {
              "type": "string",
              "enum": ["skill-wins", "baseline-wins", "tie"],
              "description": "Overall comparison verdict"
            }
          }
        }
      }
    },
    "obsolescence": {
      "type": ["object", "null"],
      "description": "Obsolescence check results (obsolescence mode only)",
      "properties": {
        "baseline_pass_rate": {
          "type": "number",
          "description": "Pass rate without skill loaded",
          "minimum": 0,
          "maximum": 1
        },
        "verdict": {
          "type": "string",
          "enum": ["obsolete", "marginal", "valuable"],
          "description": "Obsolescence classification: obsolete (>=0.9), marginal (>=0.7), valuable (<0.7)"
        }
      }
    },
    "benchmark_delta": {
      "type": ["object", "null"],
      "description": "Trend vs previous benchmark run",
      "properties": {
        "previous_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "previous_mean_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "pass_rate_delta": { "type": "number" },
        "mean_score_delta": { "type": "number" },
        "trend": {
          "type": "string",
          "enum": ["improving", "stable", "degrading"],
          "description": "Overall trend direction"
        }
      }
    },
    "total_tokens": {
      "type": "integer",
      "description": "Total tokens consumed across all cases",
      "minimum": 0
    },
    "total_duration_seconds": {
      "type": "number",
      "description": "Total wall-clock time for the eval run",
      "minimum": 0
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of the evaluation"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the evaluation completed"
    }
  },
  "additionalProperties": false
}
