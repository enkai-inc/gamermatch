{
  "$schema": "project-config-schema",
  "$comment": "Project-specific configuration. Update these values when importing .claude/ into a new repo.",
  "project": {
    "name": "gamermatch",
    "display_name": "GamerMatch",
    "description": "GamerMatch",
    "repo_owner": "enkai-inc",
    "repo_name": "gamermatch"
  },
  "paths": {
    "docs_root": "docs",
    "atlas_dir": "docs/atlas",
    "atlas_features_dir": "docs/atlas/features",
    "atlas_tiers": {
      "strategic": "docs/atlas/tier1-strategic",
      "architecture": "docs/atlas/tier2-architecture",
      "implementation": "docs/atlas/tier4-implementation"
    },
    "design_dir": "docs/design",
    "feature_spec_template": "docs/atlas/tier4-implementation/01-feature-specification-template.md",
    "dashboard_dir": "dashboard",
    "builder_dir": "builder",
    "infra_dir": "infra/cdk",
    "test_uat_dir": "dashboard/src/tests/uat"
  },
  "context_files": [
    "CLAUDE.md",
    "PROJECT_SPEC.md",
    "MILESTONES.md"
  ],
  "github": {
    "labels": {
      "build": "enkai:build",
      "in_progress": "enkai:in-progress",
      "pr_open": "enkai:pr-open",
      "done": "enkai:done",
      "needs_human": "enkai:needs-human"
    }
  },
  "aws": {
    "profile": "default",
    "region": "us-east-1",
    "stack_prefix": "GamerMatch",
    "stacks": {
      "dns": "${stack_prefix}DNSAuthStack-dev",
      "builder": "${stack_prefix}BuilderStack-dev",
      "dashboard": "${stack_prefix}DashboardStack-dev"
    },
    "services": {
      "dashboard_url": "https://gamermatch.digitaldevops.io",
      "api_url": "https://api.gamermatch.digitaldevops.io"
    }
  },
  "secrets": {
    "prefix": "gamermatch",
    "pattern": "${prefix}/{environment}/*"
  },
  "worktree": {
    "base_dir_pattern": "../worktree-{purpose}-{id}",
    "bugfix_pattern": "../bugfix-{session_id}",
    "scrum_pattern": "../worktree-scrum-{n}"
  },
  "scrum": {
    "worker_count": 6,
    "poll_interval_seconds": 15,
    "work_unit_timeout_minutes": 5
  },
  "monitoring": {
    "log_groups": [],
    "dashboards": [],
    "alarms": []
  },
  "marketing": {
    "product_name": "GamerMatch",
    "tagline": "Product tagline",
    "target_audience": "Gamers",
    "key_features": [],
    "differentiators": []
  },
  "token_optimization": {
    "cache_prefix": "gamermatch",
    "s3_bucket_env_var": "CLAUDE_ATLAS_CACHE_BUCKET",
    "warn_threshold_tokens": 30000,
    "critical_threshold_tokens": 50000
  },
  "context_modes": {
    "default": "dev",
    "contexts_dir": ".claude/contexts",
    "modes": {
      "dev": {
        "file": "dev.md",
        "description": "Implementation focus — write code, run tests, iterate",
        "skills": [
          "eval",
          "build",
          "bug",
          "execute",
          "feature-dev",
          "tdd-discipline",
          "deploy",
          "mcp-builder",
          "maint",
          "deps",
          "rollback",
          "clean"
        ]
      },
      "research": {
        "file": "research.md",
        "description": "Exploration focus — read widely, document findings, recommend",
        "skills": [
          "dd",
          "design",
          "idea",
          "observatory",
          "plan",
          "confidence-check"
        ]
      },
      "review": {
        "file": "review.md",
        "description": "Analysis focus — read thoroughly, prioritize by severity, suggest fixes",
        "skills": [
          "code-review",
          "critic",
          "checker",
          "verify",
          "gh-triage",
          "correct-course",
          "skill-eval"
        ]
      }
    }
  }
}
